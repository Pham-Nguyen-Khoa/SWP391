footer.footer.sticky-bottom 
    .footer-container(style="margin: 0 30px;")
        .row
            .map.col-md-2
                #mapEmbed
                    != SettingGeneral.MapEmbed  
            .footer-content.col-md-10.p-0(style="display: flex; justify-content: center; align-items: center;")
                .service-footer(style="max-width: 300px;").mr-5
                    h2(style="margin-left: 37px;margin-bottom: 20px;color: #ffcc00;") Dịch vụ
                    ul.services-list(style="font-size: 18px;")
                        li.services-item 
                            a(class = "services-item-link" href = '') ◉ Tư vấn và cải thiện hồ 
                        li.services-item 
                            a(class = "services-item-link" href = '') ◉ Khám bệnh 
                        li.services-item 
                            a(class = "services-item-link" href = '') ◉ Tư vấn online
                .about-footer(style="max-width: 300px;").mr-5
                    h2(style="margin-left: 37px;margin-bottom: 20px;color: #ffcc00;")  Thông tin
                    ul.about-us-list(style="font-size: 18px;")
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  '') ◉ Về chúng tôi
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  '') ◉ Cộng đồng
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  '') ◉ Chính sách 

                .contact-footer(style="max-width: 300px;").mr-5
                    h2(style="margin-left: 37px;margin-bottom: 20px;color: #ffcc00;")  Liên hệ
                    ul.info-list(style="font-size: 18px;")   
                        li.info-item 📧 #{SettingGeneral.Email}
                        li.info-item 📞 #{SettingGeneral.PhoneNumber}
                        li.info-item 🕒 #{SettingGeneral.TimeOpen} 
                .address-footer(style="max-width: 300px;").mr-3
                    h2(style=" margin-bottom: 20px;color: #ffcc00;")  Địa chỉ
                    p.adress 🏠 #{SettingGeneral.Address}
                .about-footer(style="max-width: 300px;")
                    h2(style="margin-left: 37px;margin-bottom: 20px;color: #ffcc00;")  Mạng xã hội
                    ul.about-us-list(style="font-size: 18px;")
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  SettingGeneral.Instagram target="_blank") <i class="fa-brands fa-instagram"></i> Instagram
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  SettingGeneral.Facebook target="_blank") <i class="fa-brands fa-facebook"></i> Facebook
                        li.about-us-item 
                            a(class = "about-us-item-link" href =  SettingGeneral.Messenger target="_blank") <i class="fa-brands fa-facebook-messenger"></i> Messager 
    .copyright #{SettingGeneral.Copyright}