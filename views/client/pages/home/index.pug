extends ../../layouts/default.pug
include ../../mixins/back-to-top.pug
block main

         
        //- img.img-banner(src="https://files.oaiusercontent.com/file-97ewqLfwV55B2xgkMar2ri0i?se=2024-10-03T16%3A31%3A00Z&sp=r&sv=2024-08-04&sr=b&rscc=max-age%3D604800%2C%20immutable%2C%20private&rscd=attachment%3B%20filename%3D9083723b-b88a-48f3-8740-aa976b7d7245.webp&sig=0YkzDZYxeYz4jea06G0sOyLvjEkaLwtwnKHjV0mi9jA%3D" alt="Banner Image")
        //- img.img-banner(src="/images/KoiBanner.jpg" alt="Banner Image")
        .banner(style=`background-image: url('${SettingGeneral.BannerHome}')`)


        //- section.intro
        //- .marquee-container
        //-     .fish-background
        //-     .marquee
        //-         p Chào Mừng Bạn Đến Với HealthyKoi

            //- h3.intro-title.text-center Chào Mừng Bạn Đến Với HealthyKoi
            //- p.intro-content Chúng tôi tự hào cung cấp dịch vụ chăm sóc sức khỏe toàn diện cho cá Koi, từ đánh giá ao nuôi, khám chữa bệnh đến tư vấn trực tuyến. Với đội ngũ bác sĩ thú y giàu kinh nghiệm và sự tận tâm, chúng tôi cam kết mang đến môi trường sống lý tưởng và sự chăm sóc tốt nhất cho những chú cá Koi của bạn.   
        section.service
            h3.intro-title.text-center Các Dịch Vụ Của Chúng Tôi
            .row(style="justify-content: space-around;")
                .col-md-4
                    .service-title
                    .service-content
                    .image-container
                        img(src=SettingGeneral.ImageServiceHealthy  alt="Dịch vụ 1" style="width: 100%; height:100%; object-fit: cover;")
                        h3.text-center.font-weight-bold(style="height: 75px; background-color: #9AD1E0; border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; padding-top: 25px,") Khám Bệnh
                        .overlay
                            p.mx-3 Chúng tôi cung cấp dịch vụ khám bệnh chuyên sâu dành cho cá Koi, giúp phát hiện sớm các vấn đề về sức khỏe và đảm bảo cá Koi của bạn luôn trong tình trạng tốt nhất. Đội ngũ bác sĩ giàu kinh nghiệm sẽ kiểm tra tổng quát, phát hiện bệnh lý và đề xuất các phương pháp điều trị hiệu quả nhất.  
                            button.cta(onclick="window.location.href='/koi/checkUp'" )
                                span Tìm hiểu thêm
                                svg(width="15px" height="10px" viewBox="0 0 13 10")
                                    path(d="M1,5 L11,5")
                                    polyline(points="8 1 12 5 8 9")
                .col-md-4
                    .service-title
                    .service-content
                    .image-container
                        img(src=SettingGeneral.ImageServicePond alt="Dịch vụ 2" style="width: 100%; height:100%; object-fit: cover;")
                        h3.text-center.font-weight-bold(style="height: 75px; background-color: #9AD1E0; border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; padding-top: 25px") Tư Vấn Cải Thiện Môi Trường Hồ 
                        .overlay
                            p.mx-3 Môi trường sống lý tưởng là yếu tố quan trọng đối với sức khỏe của cá Koi. Chúng tôi cung cấp dịch vụ tư vấn để đánh giá và cải thiện chất lượng nước, thiết kế hồ nuôi phù hợp và điều chỉnh các yếu tố môi trường để cá Koi của bạn phát triển khoẻ mạnh.         
                            button.cta(onclick="window.location.href='/koi/envConsult'")
                                span Tìm hiểu thêm
                                svg(width="15px" height="10px" viewBox="0 0 13 10")
                                    path(d="M1,5 L11,5")
                                    polyline(points="8 1 12 5 8 9") 
                .col-md-4
                    .service-title
                    .service-content
                    .image-container
                        img(src=SettingGeneral.ImageServiceOnline  alt="Dịch vụ 3" style="width: 100%; height:100%; object-fit: cover;") 
                        h3.text-center.font-weight-bold(style="height: 75px; background-color: #9AD1E0; border-bottom-left-radius: 20px; border-bottom-right-radius: 20px; padding-top: 25px ") Tư Vấn Trực Tuyến
                        .overlay
                            p.mx-3 Dịch vụ tư vấn trực tuyến của chúng tôi mang đến sự tiện lợi cho bạn, giúp bạn nhận được sự hỗ trợ từ các bác sĩ thú y mọi lúc mọi nơi. Chỉ cần đặt lịch hẹn, bạn sẽ nhận được lời khuyên chuyên môn và các giải pháp nhanh chóng cho những vấn đề liên quan đến sức khỏe của cá Koi.
                            button.cta(onclick="window.location.href='/koi/onlConsult'" )
                                span Tìm hiểu thêm
                                svg(width="15px" height="10px" viewBox="0 0 13 10")
                                    path(d="M1,5 L11,5")
                                    polyline(points="8 1 12 5 8 9")  
        section.profession.pt-4.pb-4(style="background-color: #e7e7e7")
            h3.intro-title.text-center.mb-5 Sự Chăm Sóc Tốt Nhất Dành Cho Những Chú Cá Koi Của Bạn
            .row
                .col-md-4   
                    .card.profession-card
                        img.profession-card-img(src="/images/doctor.avif" alt="Dịch vụ 1" style="height: 350px; object-fit: inherit; width: 100%;")
                        h3.text-center.card-title Những chuyên gia bạn có thể trông cậy
                .col-md-4   
                    .card.profession-card
                        img.profession-card-img(src="/images/bangCap.webp" alt="Dịch vụ 1" style="height: 350px; object-fit: inherit; width: 100%;")
                        h3.text-center.card-title Các bác sĩ được đào tạo và có bằng cấp chuyên môn
                .col-md-4   
                    .card.profession-card
                        img.profession-card-img(src="/images/helpCustomer.jpg" alt="Dịch vụ 1" style="height: 350px; object-fit: inherit; width: 100%;"  )
                        h3.text-center.card-title Đội ngũ chăm sóc khách hàng 24/7
        //- hr.seperate-line 
        section.review.pt-4.pb-4(style="background-color: #E3F2FD")
            div.reviews-container
                h3.intro-title.text-center.mb-5 Đánh Giá Của Khách Hàng
                div.review-card(style="height: 250px   ; margin-top: 130px;")
                    h3 Võ Nguyễn Anh Khoa
                    div.stars ★ ★ ★ ★ ★
                    p Bác sĩ đã đến 
                div.review-card(style="height: 280px ;margin: 20px;")
                    h3 Nguyễn Trung Dũng
                    div.stars ★ ★ ★ ★ ★
                    p Bác sĩ Hải thật sự là một người chuyên nghiệp và tận tâm. Tôi đã mang cá Koi của mình đến khám và được bác sĩ tư vấn rất nhiệt tình. Cảm ơn bác sĩ đã giúp cá tôi khỏe mạnh trở lại!
                div.review-card(style="height: 250px;    margin-top: 130px;")
                    h3 Mai Phạm Nồng Hậu
                    div.stars ★ ★ ★ ★ ★
                    p Đây là lần thứ hai tôi sử dụng dịch vụ khám bệnh cho cá Koi của mình. Bác sĩ luôn kiểm tra kỹ lưỡng và tư vấn rất chuyên nghiệp. Tôi sẽ giới thiệu cho bạn bè!
        
        button.back-to-top(onclick="scrollToTop()")
            svg.svgIcon(viewBox="0 0 384 512")
                path(d="M214.6 41.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 141.2V448c0 17.7 14.3 32 32 32s32-14.3 32-32V141.2L329.4 246.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z")
            script.
                function scrollToTop() {
                    window.scrollTo({
                        top: 0,
                        behavior: 'smooth' 
                    });
                }
