mixin backToTop
    button.back-to-top(onclick="scrollToTop()")
        svg.svgIcon(viewBox="0 0 384 512")
            path(d="M214.6 41.4c-12.5-12.5-32.8-12.5-45.3 0l-160 160c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L160 141.2V448c0 17.7 14.3 32 32 32s32-14.3 32-32V141.2L329.4 246.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3l-160-160z")
    
    

    style.
        .back-to-top {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background-color: white;
            border: none;
            font-weight: 600;
            display: flex;
            align-items: center;
            justify-content: center;
            box-shadow: 0px 0px 0px 4px rgba(47, 128, 243, 0.253);
            cursor: pointer;
            transition-duration: 0.3s;
            overflow: hidden;
            position: fixed;
            left: 95%;
            bottom: 20px;
            z-index: 50;
            transform: translateX(-50%);
        }

        .svgIcon {
            width: 12px;
            transition-duration: 0.3s;
        }

        .svgIcon path {
            fill: #194C92;
        }

        .back-to-top:hover {
            width: 140px;
            border-radius: 50px;
            transition-duration: 0.3s;
            background-color: #FFD700;
            align-items: center;
        }

        .back-to-top:hover .svgIcon {
            transition-duration: 0.3s;
            transform: translateY(-200%);
        }

        .back-to-top::before {
            position: absolute;
            bottom: -20px;
            content: "Về đầu trang";
            color: black;
            font-size: 0px;
        }

        .back-to-top:hover::before {
            font-size: 13px;
            opacity: 1;
            bottom: unset;
            transition-duration: 0.3s;
        }
